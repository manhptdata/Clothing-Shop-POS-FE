# Environment Variables — Clothing Shop POS

# Sao chép file này thành .env và điền giá trị thực

# URL gốc của backend API (không có /api/v1)
VITE_API_BASE_URL=http://localhost:8080

# Cloudinary configuration for unsigned image uploads
VITE_CLOUDINARY_CLOUD_NAME=dikpkxt5m
VITE_CLOUDINARY_UPLOAD_PRESET= clothing_pos_unsigned
